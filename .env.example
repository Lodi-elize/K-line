# Web service port exposed on the server.
WEB_PORT=8081

# Optional backend API port exposed on the server.
BACKEND_PORT=9091

# Use remote MySQL in production. Do not commit your real password in .env.
# Example:
# KLINE_DATABASE_URL=mysql+pymysql://user:password@mysql-host:3306/kLineDB?charset=utf8mb4
KLINE_DATABASE_URL=

# Enable concept/module sync provider.
KLINE_SYNC_CONCEPTS=true

# Leave empty for real data provider. Use fake only for smoke tests.
KLINE_PROVIDER=
