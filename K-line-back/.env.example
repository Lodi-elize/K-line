# Copy this file to .env and fill in the remote database credentials.
# The database must already exist and use utf8mb4.
KLINE_DATABASE_URL=mysql+pymysql://user:password@host:3306/kline?charset=utf8mb4

# Optional: use the fake provider only for local demos/tests.
# KLINE_PROVIDER=fake

# Optional: enable concept module sync.
# KLINE_SYNC_CONCEPTS=1
